COIND_RPC_USER=zetacoinrpc
COIND_RPC_PASSWORD=replace_me_with_a_real_password

COIND_P2P_PORT=22011
COIND_RPC_PORT=22012

# Docker bridge-friendly default; tighten this if you know your subnet
COIND_RPC_ALLOW_IP=0.0.0.0/0
COIND_RPC_BIND=0.0.0.0

COIND_TXINDEX=1
COIND_PRUNE=0
COIND_MAXCONNECTIONS=64
COIND_EXTRA_ARGS=